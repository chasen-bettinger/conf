#!/usr/bin/env zsh
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BW_VERSION="2026.2.0"

ARCH=$(uname -m)
if [[ "$ARCH" == "arm64" ]]; then
    ASSET="bw-macos-arm64-${BW_VERSION}.zip"
    SHA256="63c736b74620280e422ce238bdbcbc267689a0ff831168959ef2124588fcc1e5"
else
    ASSET="bw-macos-${BW_VERSION}.zip"
    SHA256="60cc5109b1cdad560231e02098f1ab2d16efa821d51c6ec089cb5c3cc351b2e5"
fi

"$SCRIPT_DIR/gh-install.sh" \
    "https://github.com/bitwarden/clients/releases/download/cli-v${BW_VERSION}/${ASSET}" \
    "$SHA256" \
    bw
